# Copia este archivo a .env.local y rellena las variables.
# NUNCA commits la key real al repo.

# Server-side only — no usar prefix VITE_ para que no se exponga al cliente.
OPENAI_API_KEY=sk-tu_api_key_de_openai_aqui

# Modelo de chat. Default: gpt-4o-mini (barato, rápido).
# Alternativas: gpt-4o, gpt-4.1-mini, gpt-4.1.
OPENAI_MODEL=gpt-4o-mini

# Modelo de embeddings — usado por `npm run ingest` y por el retrieve por turno.
# Default: text-embedding-3-small (1536 dims, ~$0.02 / 1M tokens).
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Opcional: cambiar el endpoint base. Útil para Azure OpenAI o proxies.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Opcional: dónde leer el índice RAG. Default: ./data/maia-index.json
# En Lambda apunta a /var/task/data/maia-index.json (ver server/lambda.ts).
# MAIA_INDEX_PATH=./data/maia-index.json
